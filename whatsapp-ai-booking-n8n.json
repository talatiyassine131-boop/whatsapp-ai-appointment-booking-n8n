{
  "name": "WhatsApp AI Appointment Booking",
  "nodes": [
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "replace-condition-id",
              "leftValue": "={{ $json.messages[0].text.body }}",
              "operator": {
                "type": "string",
